{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "image": "latest" },
      "ios": { "image": "latest" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "image": "latest" },
      "ios": {
        "image": "latest",
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "android": { "image": "latest" },
      "ios": { "image": "latest" }
    }
  },
  "submit": {
    "production": {}
  }
}
