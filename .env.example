# =============================================================================
# Vercel (admin login + analytics + email)
# =============================================================================
# If this repo’s root is "my-portfolio" but the Next.js app lives in TTPSSWA:
#   Vercel → your project → Settings → General → Root Directory → set to: TTPSSWA
# Then: Settings → Environment Variables → add (names must match exactly):
#
#   ADMIN_PASSWORD              = strong password, min 8 characters (for /admin/login)
#   UPSTASH_REDIS_REST_URL      = from Upstash → database → REST API
#   UPSTASH_REDIS_REST_TOKEN    = from same REST API tab
#   RESEND_API_KEY              = if you send hotel booking emails via Resend
#   HOTEL_BOOKING_NOTIFY_EMAIL  = optional; where bookings are sent
#
# Enable for Production (and Preview if you want the same on preview URLs).
# Save, then Deployments → … → Redeploy (env vars apply on the next build).
# =============================================================================

# Hotel booking emails — Resend (recommended in production)
# https://resend.com — create an API key under API Keys.
#
# Vercel: Project → Settings → Environment Variables
#   Name:  RESEND_API_KEY
#   Value: re_xxxxxxxx (your secret key)
#   Environments: Production (and Preview if you want previews to send mail)
# Save, then redeploy (Deployments → … → Redeploy) so the variable is applied.
#
# If Resend fails, FormSubmit is tried automatically before showing the mailto fallback.
RESEND_API_KEY=

# Where booking notifications are delivered (default: simeondoolarsingh@hotmail.com)
# HOTEL_BOOKING_NOTIFY_EMAIL=

# Sender address — must be a domain you verified in Resend (not required for first tests with onboarding@resend.dev)
# BOOKING_FROM_EMAIL=TTPSSWA Bookings <bookings@your-verified-domain.com>

# --- Admin dashboard & analytics (Upstash Redis REST) ---
# Create a Redis database at https://upstash.com — copy REST URL + REST TOKEN.
# Used for page-view counters, per-path counts, and service request logs.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin sign-in for /admin (use a long random value; minimum 8 characters).
ADMIN_PASSWORD=
